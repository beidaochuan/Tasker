{
  "name": "tasker",
  "private": true,
  "version": "0.13.0",
  "type": "module",
  "scripts": {
    "licenses:generate": "license-checker-rseidelsohn --json --excludePrivatePackages --out public/third-party-licenses.json",
    "server": "tsx watch --env-file-if-exists=.env server/index.ts",
    "start": "node dist-server/index.js",
    "dev": "npm run licenses:generate && vite",
    "dev:full": "concurrently \"cross-env PORT=3209 npm run server\" \"npm run dev\"",
    "typecheck": "tsc -b && tsc -p server/tsconfig.test.json --noEmit",
    "build:server": "tsc -p server/tsconfig.json",
    "build": "npm run licenses:generate && npm run typecheck && npm run build:server && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"server/**/*.ts\" \"*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"server/**/*.ts\" \"*.{ts,js,json,md}\"",
    "preview": "vite preview",
    "preview:full": "concurrently \"cross-env PORT=3209 npm run server\" \"npm run preview\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "node scripts/prepare.mjs",
    "service:install": "node scripts/service-install.cjs",
    "service:uninstall": "node scripts/service-uninstall.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.17",
    "@fullcalendar/daygrid": "^6.1.17",
    "@fullcalendar/interaction": "^6.1.17",
    "@fullcalendar/react": "^6.1.17",
    "@fullcalendar/timegrid": "^6.1.17",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-virtual": "^3.13.9",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "lucide-react": "^0.525.0",
    "nanoid": "^5.1.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.57.0",
    "rrule": "^2.8.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.4",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "lint-staged": "^16.1.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "node-windows": "^0.1.14"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ],
    "server/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,js,json,md}": [
      "prettier --write"
    ]
  }
}
